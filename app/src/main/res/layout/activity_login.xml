<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Bouton retour -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_purple_btn"
            android:src="@drawable/ic_arrow_back"
            android:padding="10dp"
            android:layout_marginTop="16dp"
            android:contentDescription="Retour" />

        <!-- Logo centré -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_logo_square"
            android:src="@drawable/ic_book"
            android:padding="14dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:contentDescription="Logo" />

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bon retour !"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp" />

        <!-- Sous-titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecte-toi à ton compte Planexia"
            android:textSize="13sp"
            android:textColor="#777777"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp" />

        <!-- Label Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <!-- Champ Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="ton.email@exemple.com"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:layout_marginBottom="20dp" />

        <!-- Label Mot de passe -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mot de passe"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <!-- Champ Mot de passe -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Ton mot de passe"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:layout_marginBottom="12dp" />

        <!-- "Mot de passe oublié ?" -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mot de passe oublié ?"
            android:textSize="13sp"
            android:textColor="#6C2BD9"
            android:textStyle="bold"
            android:layout_gravity="end"
            android:padding="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Bouton Se connecter -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Se connecter"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_save_button" />

        <!-- Lien "Pas encore de compte ? Créer un compte" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pas encore de compte ? "
                android:textSize="13sp"
                android:textColor="#777777" />

            <TextView
                android:id="@+id/tvGoRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Créer un compte"
                android:textSize="13sp"
                android:textColor="#6C2BD9"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>