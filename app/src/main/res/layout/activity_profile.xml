<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- CONTENU PRINCIPAL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <!-- CARTE PROFIL VIOLETTE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#6C3FC5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Avatar + infos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <!-- Avatar cercle -->
                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginEnd="14dp">

                            <TextView
                                android:id="@+id/tvAvatarInitial"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:gravity="center"
                                android:text="B"
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_avatar_circle" />

                        </FrameLayout>

                        <!-- Nom / filière / année -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvUsername"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="brayan"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvFiliere"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="informatique"
                                android:textColor="#CCBBFF"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvAnnee"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="L2"
                                android:textColor="#AA99EE"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bouton Passer Premium -->
                    <Button
                        android:id="@+id/btnPasserPremium"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="+ Passer Premium"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="#bfafde"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="?android:attr/borderlessButtonStyle" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE PREMIUM JAUNE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFBF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ia_banner"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Titre Premium -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/star_on"
                            android:tint="@color/orange_accent"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Passe Premium"
                            android:textColor="#7A5500"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Débloque toutes les fonctionnalités"
                        android:textColor="#9A7A30"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Liste features -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp">

                        <include layout="@layout/item_premium_feature"
                            android:id="@+id/feature1" />

                        <include layout="@layout/item_premium_feature"
                            android:id="@+id/feature2" />

                        <include layout="@layout/item_premium_feature"
                            android:id="@+id/feature3" />

                        <include layout="@layout/item_premium_feature"
                            android:id="@+id/feature4" />

                    </LinearLayout>

                    <!-- Bouton Découvrir -->
                    <Button
                        android:id="@+id/btnDecouvrirPremium"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Découvrir Premium"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@drawable/bg_btn_orange_rounded"
                        style="?android:attr/borderlessButtonStyle" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE MENU (Paramètres / Notifications / Aide) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Paramètres -->
                    <LinearLayout
                        android:id="@+id/rowParametres"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_preferences"
                            android:tint="@color/text_secondary"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Paramètres"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/arrow_up_float"
                            android:tint="@color/text_secondary"
                            android:rotation="90" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="16dp"
                        android:background="#E0E0E0" />

                    <!-- Notifications -->
                    <LinearLayout
                        android:id="@+id/rowNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_popup_reminder"
                            android:tint="@color/text_secondary"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Notifications"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/arrow_up_float"
                            android:tint="@color/text_secondary"
                            android:rotation="90" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="16dp"
                        android:background="#E0E0E0" />

                    <!-- Aide & Support -->
                    <LinearLayout
                        android:id="@+id/rowAide"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_help"
                            android:tint="@color/text_secondary"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Aide &amp; Support"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/arrow_up_float"
                            android:tint="@color/text_secondary"
                            android:rotation="90" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE SE DÉCONNECTER -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:id="@+id/rowDeconnexion"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="#E24B4A"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Se déconnecter"
                        android:textColor="#E24B4A"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/card_background"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>