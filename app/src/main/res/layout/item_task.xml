<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Cercle checkbox à gauche -->
        <TextView
            android:id="@+id/viewTaskCircle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/circle_outline_purple"
            android:layout_marginEnd="14dp"/>

        <!-- Contenu central -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Titre de la tâche -->
            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titre de la tâche"
                android:textColor="#1A1A1A"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <!-- Module • Date • Ressource -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <!-- Pastille couleur module -->
                <View
                    android:id="@+id/viewModuleColor"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_dot_purple"
                    android:layout_marginEnd="5dp"/>

                <!-- Nom du module -->
                <TextView
                    android:id="@+id/tvTaskModule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <!-- Séparateur date -->
                <TextView
                    android:id="@+id/tvTaskDateSep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#BBBBBB"
                    android:textSize="12sp"
                    android:visibility="gone"/>

                <!-- Date -->
                <TextView
                    android:id="@+id/tvTaskDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:visibility="gone"/>

                <!-- Séparateur ressource -->
                <TextView
                    android:id="@+id/tvResourceSep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • ⏱"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp"
                    android:visibility="gone"/>

                <!-- Ressource / durée -->
                <TextView
                    android:id="@+id/tvTaskResource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>