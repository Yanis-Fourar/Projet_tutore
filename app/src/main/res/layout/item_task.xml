<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- EN-TÊTE DE DATE (planning uniquement) -->
    <LinearLayout
        android:id="@+id/layoutDateHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBadgeAujourdhui"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aujourd'hui"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_today"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDateHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mercredi 03/12/2025"
            android:textColor="#1A1A2E"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- CARTE DE LA TÂCHE — seule couche blanche visible -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="1dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardMaxElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <View
                android:id="@+id/viewColorBar"
                android:layout_width="4dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_color_bar"
                android:layout_marginEnd="14dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTaskTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Réviser les dérivées"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTaskSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mathématiques • 60 min"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivChronoBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:tint="#CCCCCC" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>