<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne : pastille + nom + fraction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Pastille couleur -->
            <View
                android:id="@+id/viewModuleDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_dot_purple"
                android:layout_marginEnd="10dp"/>

            <!-- Nom du module -->
            <TextView
                android:id="@+id/tvModuleProgressName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mathématiques"
                android:textColor="#1F1F1F"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <!-- Fraction + % -->
            <TextView
                android:id="@+id/tvModuleProgressFraction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5/6 (83%)"
                android:textColor="#888888"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Barre de progression -->
        <ProgressBar
            android:id="@+id/pbModule"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#7B1FA2"
            android:progressBackgroundTint="#E8E0F5"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>