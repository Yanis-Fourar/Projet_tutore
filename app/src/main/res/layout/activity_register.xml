<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Header : retour + logo centré -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_centerInParent="true"
                android:background="@drawable/book"
                android:contentDescription="Logo" />
        </RelativeLayout>

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Créer ton compte"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp" />

        <!-- Sous-titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rejoins la communauté Planexia"
            android:textSize="12sp"
            android:textColor="#777777"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Avatar central -->
        <FrameLayout
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_avatar_lavender"
                android:src="@drawable/ic_person"
                android:padding="16dp"
                android:contentDescription="Photo de profil" />

            <ImageView
                android:id="@+id/btnPickPhoto"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_camera_badge"
                android:src="@drawable/ic_camera"
                android:padding="5dp"
                android:contentDescription="Changer la photo" />
        </FrameLayout>

        <!-- Pseudo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pseudo *"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etPseudo"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Ton nom d'utilisateur"
            android:textColorHint="#9CA3AF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email *"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_edit_text"
            android:hint="ton.email@exemple.com"
            android:textColorHint="#9CA3AF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Mot de passe -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mot de passe *"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Au moins 6 caractères"
            android:textColorHint="#9CA3AF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="textPassword"
            android:autofillHints="newPassword"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Filière -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filière *"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etFiliere"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Ex: Informatique, Médecine..."
            android:textColorHint="#9CA3AF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Année -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Année d'étude *"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etAnnee"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Ex: 1, 2, 3..."
            android:textColorHint="#9CA3AF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:maxLength="10"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- Bouton Créer mon compte -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Créer mon compte"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_gradient" />

    </LinearLayout>
</ScrollView>