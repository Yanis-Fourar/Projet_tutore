<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Logo centré -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/book"
            android:padding="18dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="Logo Planexia" />

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenue sur Planexia"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp" />

        <!-- Sous-titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Commence ton parcours d'apprentissage"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="48dp" />

        <!-- Bouton "Créer un compte" avec icône personne+ -->
        <Button
            android:id="@+id/btnGoRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Créer un compte"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_gradient"
            android:drawableStart="@drawable/ic_person_add"
            android:drawablePadding="10dp"
            android:paddingStart="80dp"
            android:paddingEnd="80dp" />

        <!-- Bouton "Se connecter" outline avec icône login -->
        <Button
            android:id="@+id/btnGoLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Se connecter"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_outline"
            android:drawableStart="@drawable/ic_login"
            android:drawablePadding="10dp"
            android:paddingStart="80dp"
            android:paddingEnd="80dp"
            android:layout_marginTop="14dp" />

        <!-- Mention légale -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="En continuant, tu acceptes nos conditions d'utilisation et notre politique de confidentialité"
            android:textColor="#999999"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>